# Copy this file to `.streamlit/secrets.toml` (locally) or paste its contents
# into Streamlit Community Cloud → your app → Settings → Secrets.
#
# You only need the key(s) for the provider(s) you actually use.
# Leave the rest out. Never commit real keys to git.

# Gemini 2.5 Flash (Google AI Studio key) — https://aistudio.google.com/apikey
GEMINI_API_KEY = "your-google-ai-studio-key"

# Qwen2.5-7B-Instruct via OpenRouter (exact paper model)
# https://openrouter.ai/keys
OPENROUTER_API_KEY = "your-openrouter-key"

# Qwen2.5-7B-Instruct-Turbo via Together AI (exact model; free signup credit, no card)
# https://api.together.xyz  → Settings → API Keys
TOGETHER_API_KEY = "your-together-key"

# Qwen2.5-7B-Instruct via HuggingFace Inference router (use a ':provider' suffix on the model)
# https://huggingface.co/settings/tokens  (Read token, hf_...)
HF_TOKEN = "your-hf-token"

# Custom OpenAI-compatible server (DeepInfra/Novita/Hyperbolic/your own vLLM, etc.)
CUSTOM_API_KEY = "your-custom-server-key"

# Qwen2.5-7B-Instruct via DeepInfra (exact paper model)
# https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY = "your-deepinfra-key"

# Qwen3-32B via Cerebras (fastest; NOT 2.5-7B) — https://cloud.cerebras.ai
CEREBRAS_API_KEY = "your-cerebras-key"

# Claude judge for the five quality criteria (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY = "your-anthropic-key"
